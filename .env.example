# Path to the directory the file manager will serve.
# In Kubernetes, set this to your PVC mount path (e.g. /data or /media).
# In local dev, leave unset — defaults to ./data in the project root.
MOUNT_PATH=/data

# Upload chunk size in bytes. Defaults to 512 KiB (safe for nginx default
# client_max_body_size of 1 MiB). Set to a larger value after configuring
# client_max_body_size 0 at every nginx layer. Example: 10485760 = 10 MiB.
# This is a runtime env var — no rebuild needed when changed in k8s.
# CHUNK_SIZE=10485760
