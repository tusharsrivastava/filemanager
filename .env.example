# Path to the directory the file manager will serve.
# In Kubernetes, set this to your PVC mount path (e.g. /data or /media).
# In local dev, leave unset — defaults to ./data in the project root.
MOUNT_PATH=/data

# Upload chunk size in bytes. Default is 512 KiB, which is safe for any
# nginx setup using the default client_max_body_size of 1 MiB.
# Increase this only after setting client_max_body_size 0 at every nginx
# layer (ingress controller + any external reverse proxy).
# Example: 10485760 = 10 MiB
# NEXT_PUBLIC_CHUNK_SIZE=524288
